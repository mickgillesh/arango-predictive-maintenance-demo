# ArangoDB cloud instance
ARANGO_URL=https://<your-instance>.arango.cloud/
ARANGO_DB=predictive-maintenance
ARANGO_USER=<service-account-user>
ARANGO_PASSWORD=<service-account-password>

# LangChain / OpenAI — AI-assisted AQL query generation
# The app uses ArangoGraphQAChain to translate natural-language questions into
# AQL, execute them against the database, and return a natural-language answer.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o   # optional; default is gpt-4o

# Optional: comma-separated engine IDs pinned to critical for rehearsed demos
# FORCED_CRITICAL=42,7
